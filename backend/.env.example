# PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cloud_threat_detection

# JWT signing configuration.
JWT_SECRET_KEY=replace-with-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS integration placeholders.
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_REGION=us-east-1

# CloudWatch and SNS integration.
CLOUDWATCH_LOG_GROUP_NAME=cloud-threat-detection-system
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:cloud-threat-detection-topic

# Runtime mode.
DEBUG=false
